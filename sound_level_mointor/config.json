{
  "name": "Sound Level Monitor",
  "version": "1.0",
  "slug": "sound_level_monitor",
  "description": "RTSP audio to dB via MQTT",
  "startup": "services",
  "boot": "auto",
  "arch": ["amd64", "aarch64", "armv7", "i386"],
  "build_from": {
  "amd64": "ghcr.io/home-assistant/amd64-base:3.19",
  "aarch64": "ghcr.io/home-assistant/aarch64-base:3.19",
  "armv7": "ghcr.io/home-assistant/armv7-base:3.19",
  "i386": "ghcr.io/home-assistant/i386-base:3.19"
  }
  "options": {
    "cameras": [],
    "sampling_seconds": 2,
    "smoothing_window": 5,
    "noise_threshold_db": 60,
    "mqtt": {
      "host": "core-mosquitto",
      "username": "",
      "password": ""
    }
  },
  "schema": {
    "cameras": [
      {
        "name": "str",
        "rtsp": "str"
      }
    ],
    "sampling_seconds": "int",
    "smoothing_window": "int",
    "noise_threshold_db": "int",
    "mqtt": {
      "host": "str",
      "username": "str",
      "password": "str"
    }
  }
}
